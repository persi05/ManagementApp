DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SECURE_PROXY_SSL_HEADER=false
DJANGO_USE_X_FORWARDED_HOST=false

POSTGRES_DB=dcode_management
POSTGRES_USER=dcode_management
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://dcode_management:change-me@postgres:5432/dcode_management
REDIS_URL=redis://redis:6379/1

LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
SESSION_COOKIE_AGE_SECONDS=36000
SESSION_EXPIRE_AT_BROWSER_CLOSE=false

DOCUMENTS_MAX_UPLOAD_SIZE_BYTES=52428800
DOCUMENTS_MAX_FILES_PER_USER=1000
DOCUMENTS_ALLOWED_UPLOAD_EXTENSIONS=pdf,jpg,jpeg,png,webp,gif,doc,docx,xls,xlsx,csv,txt,rtf,odt,ods,ppt,pptx

NOTIFICATIONS_PER_PAGE=50
NOTIFICATIONS_READ_RETENTION_DAYS=30
NOTIFICATIONS_UNREAD_RETENTION_DAYS=90
